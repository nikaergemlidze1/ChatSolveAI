# ── Required ─────────────────────────────────────────────────────────────────
# OpenAI API key — used for embeddings + chat completions.
OPENAI_API_KEY=

# ── Backend security ─────────────────────────────────────────────────────────
# Shared secret between Streamlit frontend and FastAPI backend. When set,
# every /chat, /suggest, /feedback, DELETE /chat/session/* request must
# include `X-API-Key: <value>`. Leave empty to disable auth (local dev).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# Comma-separated list of CORS origins allowed to call the backend.
# Production: set to your Streamlit Cloud / HF Spaces frontend URL(s).
# Default already covers local Docker / Streamlit dev.
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000,http://127.0.0.1:8501

# ── Backend wiring ───────────────────────────────────────────────────────────
# MongoDB connection string. Docker Compose injects mongodb://mongo:27017.
# Local-without-Docker default: mongodb://localhost:27017
MONGO_URL=mongodb://localhost:27017

# Streamlit calls FastAPI at this URL. Docker Compose injects http://api:8000.
# Local-without-Docker default: http://localhost:8000
API_URL=http://localhost:8000

# Password for the Streamlit admin dashboard page. Leave empty to disable the
# admin page. Configure as a Streamlit secret in production.
ADMIN_PASSWORD=

# Health check tuning (Streamlit → API).
API_HEALTH_TIMEOUT=20
API_HEALTH_RETRIES=2

# Streamlit uses /chat/stream for token-by-token responses by default.
# Set false to fall back to blocking /chat.
USE_STREAMING=true

# ── MongoDB retention ────────────────────────────────────────────────────────
# Days before query_logs / feedback / latency / sessions docs auto-expire.
# Server enforces via TTL indexes created at app startup.
MONGO_TTL_DAYS=90

# Cap on per-session messages array length (trimmed via $push $slice).
MAX_SESSION_MESSAGES=200

# ── Logging ──────────────────────────────────────────────────────────────────
# Output level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO
# Output format: json (production / log shippers) or text (local dev).
LOG_FORMAT=json

# ── Sentry (optional error reporting) ────────────────────────────────────────
# Set to your Sentry project DSN to enable error / performance capture.
# Leave empty in dev — Sentry is auto-disabled when DSN is empty.
SENTRY_DSN=
# Fraction (0.0–1.0) of transactions to sample for performance tracing.
SENTRY_TRACES_SAMPLE_RATE=0.0
# Tag events with this environment name (development, staging, production).
SENTRY_ENVIRONMENT=production
# Optional release version (commit SHA, semver tag, etc.) for source maps.
SENTRY_RELEASE=

# ── In-process cache tuning ──────────────────────────────────────────────────
# Cache vector retrieval for repeated standalone questions. Set size or TTL to
# 0 to disable.
RAG_RETRIEVAL_CACHE_SIZE=256
RAG_RETRIEVAL_CACHE_TTL=900

# Cache LLM-generated follow-up suggestions for repeated answers.
SUGGEST_CACHE_SIZE=256
SUGGEST_CACHE_TTL=900
